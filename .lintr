linters: linters_with_defaults(
  defaults           = megaverse::full_linters(),
  indentation_linter = NULL,
  object_name_linter = NULL
  )
exclusions: list(
  "R/create-train.R" = list(object_usage_linter = 80),
  "R/calc-auc.R"     = list(commented_code_linter = 146:149),
  "R/plot-emp-roc.R" = list(cyclocomp_linter = Inf),
  "R/RcppExports.R"  = list(trailing_blank_lines_linter = Inf),
  "tests/testthat/helper.R",
  "tests/testthat.R"
  )
